---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { cityPages } from '../../content/cities.ts';
import { reviews } from '../../content/reviews.ts';
import { services } from '../../content/services.ts';
import type { CityPage } from '../../content/cities.ts';

export async function getStaticPaths() {
  return cityPages.map(city => ({
    params: { city: city.slug },
    props: { city },
  }));
}

interface Props {
  city: CityPage;
}

const { city } = Astro.props;
const cityReviews = reviews.filter(r => city.relatedReviewIds.includes(r.id));
const featuredServices = services.slice(0, 6);
const otherCities = cityPages.filter(c => c.slug !== city.slug);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.loushvac303.com/" },
    { "@type": "ListItem", "position": 2, "name": "Service Area", "item": "https://www.loushvac303.com/service-area/" },
    { "@type": "ListItem", "position": 3, "name": city.name, "item": `https://www.loushvac303.com/service-area/${city.slug}/` }
  ]
};

const cityServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `HVAC Service in ${city.name}, CO`,
  "description": city.metaDescription,
  "provider": {
    "@type": "HVACBusiness",
    "name": "Lou's Heating & Cooling",
    "telephone": "+13039498584",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1880 S Pierce St #5",
      "addressLocality": "Lakewood",
      "addressRegion": "CO",
      "postalCode": "80232",
      "addressCountry": "US"
    }
  },
  "areaServed": { "@type": "City", "name": `${city.name}, CO` },
  "url": `https://www.loushvac303.com/service-area/${city.slug}/`
};
---
<BaseLayout
  title={city.metaTitle}
  description={city.metaDescription}
  canonical={`/service-area/${city.slug}/`}
  schema={[breadcrumbSchema, cityServiceSchema]}
>
  <section class="page-hero section-primary section-sm">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> &rsaquo; <a href="/service-area/">Service Area</a> &rsaquo; {city.name}
      </nav>
      <h1>{city.h1}</h1>
      <p>{city.specialty}{city.isHQ ? ' • Lou\'s HQ city' : ''}</p>
      <div class="hero-cta">
        <a href="tel:3039498584" class="btn btn-primary btn-lg">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="18" height="18"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.17h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.29 6.29l1.02-.52a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call (303) 949-8584
        </a>
        <a href="/contact/" class="btn btn-secondary">Schedule Free Estimate</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-narrow">
      <p class="city-intro">{city.intro}</p>

      <h2>Neighborhoods we serve in {city.name}</h2>
      <ul class="neighborhood-chips">
        {city.neighborhoods.map(n => <li>{n}</li>)}
      </ul>

      <h2>Local context</h2>
      <p>{city.housingNote}</p>
      <p>{city.localAngle}</p>

      <div class="city-map">
        <iframe
          src={`https://maps.google.com/maps?q=${city.mapEmbedQuery}&output=embed`}
          width="100%"
          height="320"
          loading="lazy"
          title={`Map of Lou's Heating & Cooling service area in ${city.name}, CO`}
          style="border:0; border-radius: 0.5rem;"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="text-center">HVAC services in {city.name}</h2>
      <div class="grid-3">
        {featuredServices.map(service => (
          <ServiceCard
            title={service.shortTitle}
            description={service.description}
            icon={service.icon}
            href={`/services/${service.slug}/`}
          />
        ))}
      </div>
    </div>
  </section>

  {cityReviews.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="text-center">What {city.name} customers say</h2>
        <div class="grid-3">
          {cityReviews.map(r => <ReviewCard review={r} />)}
        </div>
      </div>
    </section>
  )}

  <section class="section section-alt">
    <div class="container-narrow text-center">
      <h2>Other cities we serve</h2>
      <div class="other-cities">
        {otherCities.map(c => (
          <a href={`/service-area/${c.slug}/`}>{c.name}</a>
        ))}
        <a href="/service-area/">All service areas</a>
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>

<style>
.breadcrumb { color: rgba(255,255,255,0.7); font-size: var(--font-size-sm); margin-bottom: var(--space-3); }
.breadcrumb a { color: rgba(255,255,255,0.85); text-decoration: none; }
.breadcrumb a:hover { color: white; }
.page-hero h1 { color: var(--color-white); margin-bottom: var(--space-3); }
.page-hero p { color: rgba(255,255,255,0.85); margin-bottom: var(--space-4); }
.hero-cta { display: flex; gap: var(--space-3); flex-wrap: wrap; }
.city-intro { font-size: var(--font-size-lg); line-height: 1.8; color: var(--color-text-muted); margin-bottom: var(--space-8); }
.container-narrow h2 { color: var(--color-primary); margin-top: var(--space-8); margin-bottom: var(--space-3); }
.container-narrow h2:first-of-type { margin-top: 0; }
.neighborhood-chips { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-6); }
.neighborhood-chips li { padding: var(--space-2) var(--space-3); background: var(--color-bg-alt); border-radius: var(--border-radius-full); font-size: var(--font-size-sm); color: var(--color-text); }
.city-map { margin-top: var(--space-6); }
.grid-3 { display: grid; grid-template-columns: 1fr; gap: var(--space-6); }
@media (min-width: 640px) { .grid-3 { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .grid-3 { grid-template-columns: repeat(3, 1fr); } }
.other-cities { display: flex; gap: var(--space-3); flex-wrap: wrap; justify-content: center; margin-top: var(--space-4); }
.other-cities a { padding: var(--space-2) var(--space-4); background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--border-radius-full); color: var(--color-primary); text-decoration: none; font-weight: 500; font-size: var(--font-size-sm); }
.other-cities a:hover { background: var(--color-primary); color: var(--color-white); border-color: var(--color-primary); }
.text-center { text-align: center; }
</style>
