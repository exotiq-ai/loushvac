---
import BaseLayout from '../layouts/BaseLayout.astro';
import { services } from '../content/services.ts';
---
<BaseLayout
  title="Page Not Found | Lou's Heating & Cooling"
  description="That page wasn't found. Browse our HVAC services or call (303) 949-8584 for help."
>
  <section class="page-hero section-primary section-sm">
    <div class="container text-center">
      <p class="hero-eyebrow">404</p>
      <h1>That page didn't pan out.</h1>
      <p>The link you followed may be old, or the page moved. Here are some quick ways to find what you need.</p>
    </div>
  </section>

  <section class="section">
    <div class="container-narrow">
      <h2>Need help right now?</h2>
      <p>If your HVAC isn't working and you need someone fast, call us. A real person answers, 24/7.</p>
      <div class="not-found-cta">
        <a href="tel:3039498584" class="btn btn-primary btn-lg">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="18" height="18"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.17h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.29 6.29l1.02-.52a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call (303) 949-8584
        </a>
        <a href="/contact/" class="btn btn-outline">Schedule Free Estimate</a>
      </div>

      <h2>Or pick a service</h2>
      <ul class="not-found-services">
        {services.map(service => (
          <li>
            <a href={`/services/${service.slug}/`}>
              <strong>{service.shortTitle}</strong>
              <span>{service.description}</span>
            </a>
          </li>
        ))}
      </ul>

      <h2>Other places to start</h2>
      <ul class="not-found-links">
        <li><a href="/">Homepage</a></li>
        <li><a href="/about/">About Lou</a></li>
        <li><a href="/reviews/">Reviews</a></li>
        <li><a href="/faq/">HVAC FAQ</a></li>
        <li><a href="/service-area/">Service Area</a></li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
.hero-eyebrow { color: var(--color-primary-light); font-size: var(--font-size-sm); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-3); }
.not-found-cta { display: flex; gap: var(--space-3); flex-wrap: wrap; margin: var(--space-4) 0 var(--space-10); }
.not-found-services { list-style: none; padding: 0; display: grid; grid-template-columns: 1fr; gap: var(--space-3); margin-bottom: var(--space-10); }
@media (min-width: 640px) { .not-found-services { grid-template-columns: 1fr 1fr; } }
.not-found-services li a { display: block; padding: var(--space-4); background: var(--color-bg-alt); border-radius: var(--border-radius); text-decoration: none; transition: background var(--transition); }
.not-found-services li a:hover { background: var(--color-primary); color: var(--color-white); }
.not-found-services strong { display: block; color: var(--color-primary); margin-bottom: var(--space-1); }
.not-found-services li a:hover strong { color: var(--color-white); }
.not-found-services span { font-size: var(--font-size-sm); color: var(--color-text-muted); }
.not-found-services li a:hover span { color: rgba(255,255,255,0.85); }
.not-found-links { list-style: none; padding: 0; display: flex; gap: var(--space-3); flex-wrap: wrap; }
.not-found-links a { padding: var(--space-2) var(--space-4); background: var(--color-bg-alt); border-radius: var(--border-radius-full); color: var(--color-primary); text-decoration: none; font-size: var(--font-size-sm); font-weight: 500; }
.not-found-links a:hover { background: var(--color-primary); color: var(--color-white); }
</style>
