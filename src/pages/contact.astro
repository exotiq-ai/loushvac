---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { externalProfiles } from '../content/externalProfiles.ts';
---
<BaseLayout
  title="Contact Lou's Heating & Cooling | Denver HVAC | (303) 949-8584"
  description="Contact Lou's Heating & Cooling in Denver. Call (303) 949-8584 for 24/7 emergency service, free estimates, and HVAC questions. Serving Denver since 2014."
  canonical="/contact/"
>
  <section class="page-hero section-primary section-sm">
    <div class="container text-center">
      <h1>Contact Lou's Heating & Cooling</h1>
      <p>For emergencies, call us directly. For estimates and non-urgent questions, use the form below.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-layout">
      <div class="contact-info">
        <h2>Get in Touch</h2>
        <div class="contact-detail contact-phone-big">
          <a href="tel:3039498584">(303) 949-8584</a>
          <span>Available 24/7 for emergencies</span>
        </div>
        <div class="contact-detail">
          <h3>Email</h3>
          <a href="mailto:lousheatingcooling@icloud.com">lousheatingcooling@icloud.com</a>
        </div>
        <div class="contact-detail">
          <h3>Address</h3>
          <p>2715 S Eaton Way<br />Denver, CO 80227</p>
        </div>
        <div class="contact-detail">
          <h3>Hours</h3>
          <p><strong>Service:</strong> 24/7 — Emergency service always available</p>
          <p><strong>Office calls:</strong> Mon–Sat, 7am–8pm</p>
        </div>
        <div class="contact-detail">
          <h3>Find Us Online</h3>
          <div class="contact-profiles">
            {externalProfiles.map(p => (
              <a href={p.url} target="_blank" rel="noopener noreferrer" class="profile-link">
                {p.icon} {p.label}
              </a>
            ))}
          </div>
        </div>
        <div class="contact-map">
          <iframe
            src="https://maps.google.com/maps?q=2715+S+Eaton+Way,+Denver,+CO+80227&output=embed"
            width="100%"
            height="250"
            loading="lazy"
            title="Lou's Heating & Cooling location map"
            style="border:0; border-radius: 0.5rem;"
            allowfullscreen
          ></iframe>
        </div>
      </div>

      <div class="contact-form-wrapper">
        <h2>Schedule Your Free Estimate</h2>
        <p>Fill out this form and we'll be in touch within 2 hours. For urgent issues, call us directly at <a href="tel:3039498584" class="phone-link">(303) 949-8584</a>.</p>
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.contact-layout { display: grid; grid-template-columns: 1fr; gap: var(--space-12); }
@media (min-width: 768px) { .contact-layout { grid-template-columns: 1fr 1.5fr; } }
.contact-info h2 { margin-bottom: var(--space-6); }
.contact-phone-big a { display: block; font-size: var(--font-size-4xl); font-weight: 800; color: var(--color-primary); text-decoration: none; line-height: 1; }
.contact-phone-big a:hover { color: var(--color-accent); }
.contact-phone-big span { font-size: var(--font-size-sm); color: var(--color-text-muted); }
.contact-detail { margin-bottom: var(--space-6); }
.contact-detail h3 { font-size: var(--font-size-sm); text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-muted); font-weight: 600; margin-bottom: var(--space-2); }
.contact-detail p { color: var(--color-text); margin: 0 0 var(--space-1); }
.contact-detail a { color: var(--color-primary); text-decoration: none; font-weight: 500; }
.contact-detail a:hover { color: var(--color-accent); text-decoration: underline; }
.contact-profiles { display: flex; flex-direction: column; gap: var(--space-2); }
.profile-link { color: var(--color-text-muted); font-size: var(--font-size-sm); text-decoration: none; display: inline-flex; align-items: center; gap: var(--space-2); }
.profile-link:hover { color: var(--color-primary); }
.contact-map { margin-top: var(--space-6); }
.contact-form-wrapper h2 { margin-bottom: var(--space-3); }
.contact-form-wrapper > p { color: var(--color-text-muted); margin-bottom: var(--space-6); }
</style>
