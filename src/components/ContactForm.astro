---
// src/components/ContactForm.astro
export interface Props { compact?: boolean; sourcePage?: string; }
const { compact = false, sourcePage } = Astro.props;
---
<form
  class:list={['contact-form', { 'contact-form--compact': compact }]}
  data-source-page={sourcePage || ''}
  novalidate
>
  <noscript>
    <p class="form-noscript">JavaScript is required to submit this form. Please enable JS or call <a href="tel:3039498584" class="phone-link">(303) 949-8584</a>.</p>
  </noscript>

  <div class="form-status" data-status hidden></div>

  <div class="form-grid">
    <div class="form-group">
      <label for="name">Your Name <span aria-hidden="true">*</span></label>
      <input type="text" id="name" name="name" required autocomplete="name" placeholder="Jane Smith" />
    </div>
    <div class="form-group">
      <label for="phone">Phone Number <span aria-hidden="true">*</span></label>
      <input type="tel" id="phone" name="phone" required autocomplete="tel" placeholder="(720) 555-0100" />
    </div>
    <div class="form-group">
      <label for="email">Email Address <span aria-hidden="true">*</span></label>
      <input type="email" id="email" name="email" required autocomplete="email" placeholder="jane@example.com" />
    </div>
    <div class="form-group">
      <label for="service">Service Needed</label>
      <select id="service" name="service">
        <option value="">-- Select a service --</option>
        <option value="ac-repair">AC Repair</option>
        <option value="ac-replacement">AC Replacement / Installation</option>
        <option value="furnace-repair">Furnace Repair</option>
        <option value="furnace-replacement">Furnace Replacement / Installation</option>
        <option value="swamp-cooler">Swamp Cooler Service</option>
        <option value="maintenance">Maintenance / Tune-Up</option>
        <option value="emergency">Emergency Service</option>
        <option value="other">Other / Not Sure</option>
      </select>
    </div>
  </div>
  {!compact && (
    <>
      <div class="form-group form-group--full">
        <label for="message">Describe Your Issue</label>
        <textarea id="message" name="message" rows="4" placeholder="Tell us what's going on with your system..."></textarea>
      </div>
      <div class="form-group form-group--full">
        <label for="preferred_time">Preferred Date / Time</label>
        <input type="text" id="preferred_time" name="preferred_time" placeholder="e.g., Weekday mornings, ASAP, After 3pm" />
      </div>
    </>
  )}
  <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
  <button type="submit" class="btn btn-primary btn-lg form-submit">
    Get My Free Estimate
  </button>
  <p class="form-disclaimer">No obligation. We'll respond within 2 hours during business hours.</p>
</form>

<script>
  document.querySelectorAll('form.contact-form').forEach((formEl) => {
    const form = formEl as HTMLFormElement;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = form.querySelector('[data-status]') as HTMLElement | null;
      const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (!status || !submit) return;

      const data: Record<string, string> = {};
      new FormData(form).forEach((v, k) => { data[k] = String(v); });
      data.source_page = (form.dataset.sourcePage || window.location.pathname);

      submit.disabled = true;
      const originalText = submit.textContent || '';
      submit.textContent = 'Sending…';
      status.hidden = true;
      status.className = 'form-status';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json().catch(() => ({}));
        if (res.ok) {
          status.textContent = json.message || 'Got it — Lou will be in touch within 2 hours.';
          status.classList.add('form-status--success');
          status.hidden = false;
          form.reset();
        } else {
          status.textContent = json.error || 'Something went wrong. Please call (303) 949-8584.';
          status.classList.add('form-status--error');
          status.hidden = false;
        }
      } catch {
        status.textContent = 'Network issue. Please call (303) 949-8584.';
        status.classList.add('form-status--error');
        status.hidden = false;
      } finally {
        submit.disabled = false;
        submit.textContent = originalText;
      }
    });
  });
</script>

<style>
.contact-form { width: 100%; }
.form-status { padding: var(--space-3) var(--space-4); border-radius: var(--border-radius); margin-bottom: var(--space-4); font-weight: 600; }
.form-status--success { background: rgba(40, 167, 69, 0.12); color: #155724; border: 1px solid rgba(40, 167, 69, 0.3); }
.form-status--error { background: rgba(220, 53, 69, 0.12); color: #721c24; border: 1px solid rgba(220, 53, 69, 0.3); }
.form-noscript { padding: var(--space-3); background: rgba(220, 53, 69, 0.1); border-radius: var(--border-radius); margin-bottom: var(--space-4); color: #721c24; }
.form-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-bottom: var(--space-4); }
@media (min-width: 640px) { .form-grid { grid-template-columns: 1fr 1fr; } }
.form-group { display: flex; flex-direction: column; gap: var(--space-1); }
.form-group--full { grid-column: 1 / -1; margin-bottom: var(--space-4); display: flex; flex-direction: column; gap: var(--space-1); }
label { font-size: var(--font-size-sm); font-weight: 600; color: var(--color-text); }
label span { color: var(--color-accent); }
input, select, textarea {
  width: 100%;
  padding: var(--space-3) var(--space-4);
  border: 1.5px solid var(--color-border);
  border-radius: var(--border-radius);
  font-size: var(--font-size-base);
  font-family: var(--font-sans);
  color: var(--color-text);
  background: var(--color-white);
  transition: border-color var(--transition);
}
input:focus, select:focus, textarea:focus {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px rgba(27,73,101,0.12);
}
textarea { resize: vertical; min-height: 100px; }
.form-submit { width: 100%; margin-top: var(--space-2); }
.form-submit[disabled] { opacity: 0.6; cursor: wait; }
.form-disclaimer { text-align: center; color: var(--color-text-muted); font-size: var(--font-size-sm); margin-top: var(--space-3); }
</style>
