---
// src/components/TrustBar.astro
---
<div class="trust-bar" role="list" aria-label="Trust and credentials">
  <div class="container trust-bar-inner">

    <!-- Row 1, Item 1: Family-Owned -->
    <div class="trust-badge" role="listitem">
      <div class="trust-icon-wrap trust-icon-primary">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="28" height="28">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
      </div>
      <div class="trust-text">
        <span class="trust-label">Family-Owned, Owner Operated</span>
        <span class="trust-sub">Faith-Driven</span>
      </div>
    </div>

    <!-- Row 1, Item 2: 24/7 Emergency Service -->
    <div class="trust-badge" role="listitem">
      <div class="trust-icon-wrap trust-icon-primary">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="28" height="28"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
      <div class="trust-text">
        <span class="trust-label">24/7 Emergency Service</span>
        <span class="trust-sub">Always Available</span>
      </div>
    </div>

    <!-- Row 1, Item 3: 5-Star (centered) -->
    <div class="trust-badge" role="listitem">
      <div class="trust-icon-wrap trust-icon-accent">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true" width="28" height="28"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </div>
      <div class="trust-text">
        <span class="trust-label">5-Star Rated</span>
        <span class="trust-sub">50+ Verified Reviews</span>
      </div>
    </div>

    <!-- Row 1, Item 4: Authorized Carrier Dealer -->
    <div class="trust-badge" role="listitem">
      <div class="trust-icon-wrap trust-icon-accent">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="28" height="28"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
      </div>
      <div class="trust-text">
        <span class="trust-label">Authorized Carrier Dealer</span>
        <span class="trust-sub">Trusted Experts</span>
      </div>
    </div>

    <!-- Row 1, Item 5: BBB A+ -->
    <div class="trust-badge" role="listitem">
      <div class="trust-icon-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="28" height="28"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
      </div>
      <div class="trust-text">
        <span class="trust-label">BBB A+ Accredited</span>
        <span class="trust-sub">Since July 2024</span>
      </div>
    </div>

    <!-- Row 2, Item 6: Industry Expert 10+ -->
    <div class="trust-badge" role="listitem">
      <div class="trust-icon-wrap trust-icon-accent">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="28" height="28"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
      </div>
      <div class="trust-text">
        <span class="trust-label">Industry Expert 10+ Years</span>
        <span class="trust-sub">Colorado Native</span>
      </div>
    </div>

    <!-- Row 2, Item 7: Financing -->
    <div class="trust-badge" role="listitem">
      <div class="trust-icon-wrap trust-icon-primary">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="28" height="28"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      </div>
      <div class="trust-text">
        <span class="trust-label">Financing Available</span>
        <span class="trust-sub">Interest-Free*</span>
      </div>
    </div>

    <!-- Row 2, Item 8: Certified HVAC Contractors -->
    <div class="trust-badge" role="listitem">
      <div class="trust-icon-wrap trust-icon-primary">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="28" height="28"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      </div>
      <div class="trust-text">
        <span class="trust-label">Certified HVAC Contractors</span>
        <span class="trust-sub">In-House Experts</span>
      </div>
    </div>

    <!-- Row 2, Item 9: 10-Year Warranty -->
    <div class="trust-badge" role="listitem">
      <div class="trust-icon-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="28" height="28"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <div class="trust-text">
        <span class="trust-label">10-Year Warranty</span>
        <span class="trust-sub">On New Equipment</span>
      </div>
    </div>

    <!-- Row 2, Item 10: Top 3 HVAC Contractors -->
    <div class="trust-badge" role="listitem">
      <div class="trust-icon-wrap trust-icon-accent">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="28" height="28"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
      </div>
      <div class="trust-text">
        <span class="trust-label">Top 3 HVAC Contractors</span>
        <span class="trust-sub">Lakewood Business Rate 2025</span>
      </div>
    </div>

  </div>
  <p class="trust-bar-footnote">*Financing subject to qualification. Approval not guaranteed.</p>
</div>
<style>
.trust-bar {
  background: linear-gradient(135deg, #0f2d42 0%, #163d56 40%, var(--color-primary) 70%, #1e5778 100%);
  color: var(--color-white);
  padding: var(--space-6) 0 var(--space-4);
  border-bottom: 4px solid var(--color-accent);
}
.trust-bar-inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-3);
  align-items: stretch;
}
@media (min-width: 480px) { .trust-bar-inner { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 768px) { .trust-bar-inner { grid-template-columns: repeat(3, 1fr); } }
@media (min-width: 1024px) { .trust-bar-inner { grid-template-columns: repeat(5, 1fr); } }
.trust-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-2);
  padding: var(--space-4) var(--space-3);
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-top: 2px solid rgba(255, 255, 255, 0.25);
  border-radius: var(--border-radius);
  transition: background 0.2s ease;
}
.trust-badge:hover { background: rgba(255, 255, 255, 0.15); }
.trust-icon-wrap {
  width: 52px;
  height: 52px;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 1px solid rgba(255, 255, 255, 0.15);
}
.trust-icon-accent {
  background: rgba(242, 140, 40, 0.35);
  border-color: rgba(242, 140, 40, 0.4);
}
.trust-icon-primary {
  background: rgba(95, 168, 211, 0.25);
  border-color: rgba(95, 168, 211, 0.3);
}
.trust-text { display: flex; flex-direction: column; gap: 3px; align-items: center; }
.trust-label {
  font-size: var(--font-size-xs);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  line-height: 1.2;
}
.trust-sub {
  font-size: 0.7rem;
  opacity: 0.85;
  font-weight: 400;
  line-height: 1.3;
}
.trust-bar-footnote {
  text-align: center;
  font-size: 0.7rem;
  opacity: 0.7;
  margin: var(--space-4) 0 0;
  font-style: italic;
  color: var(--color-white);
}
@media (min-width: 1024px) {
  .trust-label { font-size: 0.72rem; }
}
</style>
