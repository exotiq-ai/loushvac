---
// src/components/TrustBar.astro
const badges = [
  { icon: '✓', label: 'BBB A+ Accredited', sub: 'Since July 2024' },
  { icon: '⭐', label: 'American Standard Dealer', sub: 'Authorized Dealer' },
  { icon: '★★★★★', label: '5-Star Rated', sub: '50+ Reviews' },
  { icon: '🕐', label: '24/7 Emergency Service', sub: 'Always Available' },
  { icon: '📅', label: 'Serving Denver Since 2014', sub: '10+ Years Experience' },
  { icon: '🛡️', label: '10-Year Warranty', sub: 'On New Equipment' },
];
---
<div class="trust-bar" role="list" aria-label="Trust and credentials">
  <div class="container trust-bar-inner">
    {badges.map(b => (
      <div class="trust-badge" role="listitem">
        <span class="trust-icon" aria-hidden="true">{b.icon}</span>
        <div class="trust-text">
          <span class="trust-label">{b.label}</span>
          <span class="trust-sub">{b.sub}</span>
        </div>
      </div>
    ))}
  </div>
</div>
<style>
.trust-bar { background: var(--color-primary); color: var(--color-white); padding: var(--space-4) 0; }
.trust-bar-inner {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  justify-content: center;
}
.trust-badge {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-3);
}
.trust-icon { font-size: 1.25rem; flex-shrink: 0; }
.trust-text { display: flex; flex-direction: column; }
.trust-label { font-size: var(--font-size-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
.trust-sub { font-size: var(--font-size-xs); opacity: 0.8; }
</style>
