---
// src/components/Footer.astro
import { externalProfiles } from '../content/externalProfiles.ts';
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src="/images/lous-hvac-logo.png" alt="Lou's Heating & Cooling" width="200" height="67" />
      <p>Family-owned HVAC based in Lakewood,<br>serving the Denver metro since 2014.</p>
      <p class="footer-spanish">Se habla Español</p>
    </div>

    <div class="footer-contact">
      <h3>Contact</h3>
      <p><a href="tel:3039498584" class="phone-link">(303) 949-8584</a></p>
      <p><a href="mailto:lousheatingcooling@icloud.com">lousheatingcooling@icloud.com</a></p>
      <p>1880 S Pierce St #5<br>Lakewood, CO 80232</p>
      <p><strong>Hours:</strong> 24/7. Emergency service available.</p>
    </div>

    <div class="footer-nav">
      <h3>Services</h3>
      <nav aria-label="Footer services navigation">
        <a href="/services/ac-repair/">AC Repair</a>
        <a href="/services/ac-replacement/">AC Installation</a>
        <a href="/services/furnace-repair/">Furnace Repair</a>
        <a href="/services/furnace-replacement/">Furnace Installation</a>
        <a href="/services/swamp-cooler/">Swamp Cooler Service</a>
        <a href="/services/maintenance/">Maintenance</a>
        <a href="/services/emergency/">24/7 Emergency</a>
      </nav>
    </div>

    <div class="footer-cities">
      <h3>Top Cities</h3>
      <nav aria-label="Footer cities navigation">
        <a href="/service-area/lakewood/">Lakewood</a>
        <a href="/service-area/denver/">Denver</a>
        <a href="/service-area/wheat-ridge/">Wheat Ridge</a>
        <a href="/service-area/arvada/">Arvada</a>
        <a href="/service-area/golden/">Golden</a>
        <a href="/service-area/">All Service Areas</a>
      </nav>
    </div>

    <div class="footer-links">
      <h3>Company</h3>
      <nav aria-label="Footer company navigation">
        <a href="/about/">About Lou's</a>
        <a href="/reviews/">Reviews</a>
        <a href="/faq/">FAQ</a>
        <a href="/service-area/">Service Area</a>
        <a href="/contact/">Contact</a>
      </nav>
      <div class="footer-social">
        <h4>Find Us Online</h4>
        {externalProfiles.map(p => (
          <a href={p.url} target="_blank" rel="noopener noreferrer">
            <span set:html={p.icon} class="social-icon"></span>{p.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>&copy; {new Date().getFullYear()} Lou's Heating & Cooling LLC. All rights reserved.</p>
      <nav class="footer-legal" aria-label="Legal">
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
      </nav>
      <p class="footer-trust">
        BBB A+ Accredited &bull; Authorized Carrier Dealer &bull;
        Licensed &amp; Insured in Colorado
      </p>
    </div>
  </div>
</footer>

<style>
.site-footer { background: var(--color-bg-dark); color: var(--color-white); padding: var(--space-16) 0 0; }
.footer-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-10);
}
@media (min-width: 640px) { .footer-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .footer-grid { grid-template-columns: repeat(5, 1fr); } }
.footer-brand img { margin-bottom: var(--space-4); }
.footer-brand p { color: #9CA3AF; font-size: var(--font-size-sm); line-height: 1.6; margin-bottom: var(--space-2); }
.footer-spanish { color: var(--color-primary-light) !important; font-style: italic; }
.footer-contact h3, .footer-nav h3, .footer-links h3 { color: var(--color-white); font-size: var(--font-size-base); margin-bottom: var(--space-4); }
.footer-contact p { color: #9CA3AF; font-size: var(--font-size-sm); margin-bottom: var(--space-2); }
.footer-contact a { color: var(--color-primary-light); }
.footer-contact a:hover { color: var(--color-white); }
.footer-nav nav, .footer-links nav, .footer-cities nav { display: flex; flex-direction: column; gap: var(--space-2); }
.footer-nav a, .footer-links a, .footer-cities a { color: #9CA3AF; font-size: var(--font-size-sm); text-decoration: none; transition: color var(--transition); }
.footer-nav a:hover, .footer-links a:hover, .footer-cities a:hover { color: var(--color-white); }
.footer-cities h3 { color: var(--color-white); font-size: var(--font-size-base); margin-bottom: var(--space-4); }
.footer-social { margin-top: var(--space-6); }
.footer-social h4 { color: var(--color-white); font-size: var(--font-size-sm); margin-bottom: var(--space-3); font-weight: 600; }
.footer-social a { display: flex; align-items: center; gap: var(--space-2); color: #9CA3AF; font-size: var(--font-size-sm); text-decoration: none; margin-bottom: var(--space-2); }
.footer-social a:hover { color: var(--color-white); }
.social-icon { display: inline-flex; align-items: center; flex-shrink: 0; }
.footer-bottom { margin-top: var(--space-12); border-top: 1px solid #374151; padding: var(--space-6) 0; }
.footer-bottom-inner { display: flex; flex-direction: column; gap: var(--space-2); }
@media (min-width: 768px) { .footer-bottom-inner { flex-direction: row; justify-content: space-between; align-items: center; flex-wrap: wrap; } }
.footer-bottom p { color: #6B7280; font-size: var(--font-size-xs); }
.footer-trust { color: #6B7280; }
.footer-legal { display: flex; gap: var(--space-3); }
.footer-legal a { color: #9CA3AF; font-size: var(--font-size-xs); text-decoration: none; }
.footer-legal a:hover { color: var(--color-white); }
</style>
